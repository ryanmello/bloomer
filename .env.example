NEXTAUTH_URL=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

SQUARE_CLIENT_ID=
SQUARE_CLIENT_SECRET=

NEXT_PUBLIC_PUBLIC_FORM_URL=